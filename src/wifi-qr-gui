#!/usr/bin/env -S /usr/bin/python3
"""
WiFi QR Connect — GUI edition
A GTK4/libadwaita app to scan Android WiFi QR codes and auto-connect.

Uses GStreamer for live webcam preview + pyzbar for QR decoding.
Falls back to zbarimg CLI if pyzbar fails on a frame.
"""
import sys
import subprocess
import threading
import time

import gi
gi.require_version("Gtk", "4.0")
gi.require_version("Adw", "1")
gi.require_version("Gst", "1.0")
gi.require_version("Gdk", "4.0")
gi.require_version("GLib", "2.0")

from gi.repository import Gtk, Adw, Gst, Gdk, GLib, GObject, Gio

from pyzbar.pyzbar import decode as pyzbar_decode
from PIL import Image
import numpy as np

# ── Initialize GStreamer ─────────────────────────────────────────────────
Gst.init(None)


# ── QR Parsing ───────────────────────────────────────────────────────────
def parse_wifi_qr(raw: str) -> dict | None:
    """Parse an Android WIFI: QR code string.
    Returns dict with keys: ssid, auth, password, hidden — or None.
    """
    raw = raw.strip()
    # Strip common prefixes
    for prefix in ("QR-Code:", "QRCode:"):
        if raw.startswith(prefix):
            raw = raw[len(prefix):]
    if not raw.startswith("WIFI:"):
        return None

    payload = raw[5:]
    payload = payload.rstrip(";")

    # Unescape \; \: \\ before splitting
    payload = payload.replace("\\;", "__SEMI__").replace("\\:", "__COLON__").replace("\\\\", "__BSLASH__")

    ssid = ""
    auth = "nopass"
    password = ""
    hidden = "false"

    for field in payload.split(";"):
        if ":" not in field:
            continue
        key, val = field.split(":", 1)
        # restore escaped chars
        val = val.replace("__SEMI__", ";").replace("__COLON__", ":").replace("__BSLASH__", "\\")
        if key == "S":
            ssid = val
        elif key == "T":
            auth = val
        elif key == "P":
            password = val
        elif key == "H":
            hidden = val

    if not ssid:
        return None
    return {"ssid": ssid, "auth": auth, "password": password, "hidden": hidden}


def connect_wifi(info: dict) -> tuple[bool, str]:
    """Connect via nmcli. Returns (success, message)."""
    ssid = info["ssid"]
    auth = info["auth"].lower()
    password = info["password"]
    is_hidden = info["hidden"].lower() == "true"

    # Delete existing connection with same name
    subprocess.run(["nmcli", "connection", "delete", ssid],
                   capture_output=True, timeout=10)

    cmd = ["nmcli", "device", "wifi", "connect", ssid]

    # nmcli auto-detects WPA/WEP from the network itself.
    # For WEP, weep-key-type can be specified; WPA needs only password.
    if auth in ("wpa", "wpa2", "wpa3", "sae", "wpa/wpa2"):
        cmd += ["password", password]
    elif auth == "wep":
        cmd += ["password", password, "wep-key-type", "key"]
    # nopass / none: no password args

    if is_hidden:
        cmd += ["hidden", "yes"]

    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        if result.returncode == 0:
            return True, f"Connected to '{ssid}'"
        return False, f"nmcli error: {result.stderr.strip() or result.stdout.strip()}"
    except subprocess.TimeoutExpired:
        return False, "Connection timed out"
    except Exception as e:
        return False, f"Error: {e}"


# ── Camera Pipeline ──────────────────────────────────────────────────────
class CameraManager(GObject.Object):
    """Manages a GStreamer pipeline for webcam capture and QR scanning.

    Single-consumer design: _on_new_sample pulls every frame from appsink,
    stores it for the display signal AND for the scan thread. The scan
    thread never touches the appsink directly.
    """

    __gsignals__ = {
        "qr-detected": (GObject.SignalFlags.RUN_FIRST, None, (str,)),
        "frame-ready": (GObject.SignalFlags.RUN_FIRST, None, (object,)),
        "error": (GObject.SignalFlags.RUN_FIRST, None, (str,)),
    }

    def __init__(self):
        super().__init__()
        self.pipeline = None
        self.appsink = None
        self._running = False
        self._scan_thread = None
        self._last_qr_time = 0
        self._last_qr_raw = ""

        # Latest frame stashed by _on_new_sample for the scan thread
        self._latest_frame: np.ndarray | None = None
        self._frame_lock = threading.Lock()

    def start(self):
        """Start the camera pipeline."""
        if self._running:
            return

        # MJPG is the native format for most webcams (including this ThinkPad).
        # Pipeline: v4l2src → MJPG caps → jpegdec → videoconvert → RGB → appsink
        pipeline_str = (
            "v4l2src device=/dev/video0 name=src ! "
            "image/jpeg,width=640,height=480,framerate=30/1 ! "
            "jpegdec ! "
            "videoconvert ! "
            "videoscale ! "
            "video/x-raw,format=RGB,width=640,height=480 ! "
            "appsink name=sink emit-signals=true sync=false max-buffers=2 drop=true"
        )

        try:
            self.pipeline = Gst.parse_launch(pipeline_str)
        except GLib.Error as e:
            self.emit("error", f"Failed to create pipeline: {e}")
            return

        self.appsink = self.pipeline.get_by_name("sink")
        if not self.appsink:
            self.emit("error", "Could not get appsink from pipeline")
            return

        self.appsink.connect("new-sample", self._on_new_sample)

        ret = self.pipeline.set_state(Gst.State.PLAYING)
        if ret == Gst.StateChangeReturn.FAILURE:
            # Get error details from the bus
            bus = self.pipeline.get_bus()
            msg = bus.pop_filtered(Gst.MessageType.ERROR)
            detail = ""
            if msg:
                err, dbg = msg.parse_error()
                detail = f": {err.message}"
            self.emit("error", f"Failed to start camera{detail}")
            self.pipeline = None
            return

        self._running = True
        self._scan_thread = threading.Thread(target=self._scan_loop, daemon=True)
        self._scan_thread.start()

    def stop(self):
        """Stop the camera pipeline."""
        self._running = False
        if self._scan_thread:
            self._scan_thread.join(timeout=2)
        if self.pipeline:
            self.pipeline.set_state(Gst.State.NULL)
            self.pipeline = None
        self.appsink = None
        with self._frame_lock:
            self._latest_frame = None

    def _on_new_sample(self, appsink):
        """Called by GStreamer for every new frame. Single consumer of appsink.

        Pulls the sample, converts to numpy, stashes it for the scan thread,
        and emits frame-ready on the main thread for display.
        """
        sample = appsink.emit("pull-sample")
        if not sample:
            return Gst.FlowReturn.OK

        caps = sample.get_caps()
        struct = caps.get_structure(0)
        width = struct.get_value("width")
        height = struct.get_value("height")

        buf = sample.get_buffer()
        success, info = buf.map(Gst.MapFlags.READ)
        if not success:
            return Gst.FlowReturn.OK

        try:
            data = np.frombuffer(info.data, dtype=np.uint8)
            frame = data.reshape((height, width, 3)).copy()

            # Stash for scan thread
            with self._frame_lock:
                self._latest_frame = frame

            # Emit frame-ready on the GTK main thread
            GLib.idle_add(self.emit, "frame-ready", frame)
        except Exception:
            pass
        finally:
            buf.unmap(info)

        return Gst.FlowReturn.OK

    def _scan_loop(self):
        """Background thread: periodically grabs the latest stashed frame
        and runs pyzbar QR detection on it. Never touches appsink."""
        while self._running:
            time.sleep(0.4)  # Scan every 400ms

            with self._frame_lock:
                frame = self._latest_frame
            if frame is None:
                continue

            try:
                pil_img = Image.fromarray(frame)
                codes = pyzbar_decode(pil_img)

                for code in codes:
                    raw = code.data.decode("utf-8", errors="replace")
                    now = time.time()
                    # Debounce: ignore same QR within 3 seconds
                    if raw == self._last_qr_raw and (now - self._last_qr_time) < 3:
                        continue
                    self._last_qr_raw = raw
                    self._last_qr_time = now
                    GLib.idle_add(self.emit, "qr-detected", raw)
            except Exception:
                pass


# ── Paintable for camera display ─────────────────────────────────────────
class FramePaintable(GObject.Object, Gdk.Paintable):
    """A GdkPaintable that renders numpy frames for GTK4."""

    __gtype_name__ = "FramePaintable"

    def __init__(self):
        super(GObject.Object, self).__init__()
        self._texture = None
        self._width = 640
        self._height = 480

    def do_get_intrinsic_width(self):
        return self._width

    def do_get_intrinsic_height(self):
        return self._height

    def do_snapshot(self, snapshot, width, height):
        if self._texture:
            self._texture.snapshot(snapshot, width, height)

    def update_frame(self, frame: np.ndarray):
        """Update the displayed frame from a numpy array (H, W, 3) RGB."""
        h, w = frame.shape[:2]
        self._width = w
        self._height = h

        # GTK MemoryTexture expects RGBA
        rgba = np.dstack([frame, np.full((h, w, 1), 255, dtype=np.uint8)])
        gbytes = GLib.Bytes.new(rgba.tobytes())

        self._texture = Gdk.MemoryTexture.new(
            w, h,
            Gdk.MemoryFormat.R8G8B8A8,
            gbytes,
            w * 4
        )
        self.invalidate_contents()


# ── Main Application Window ──────────────────────────────────────────────
class WifiQRWindow(Adw.ApplicationWindow):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.set_title("WiFi QR Connect")
        self.set_default_size(500, 620)

        self.camera = CameraManager()
        self.camera.connect("frame-ready", self._on_frame_ready)
        self.camera.connect("qr-detected", self._on_qr_detected)
        self.camera.connect("error", self._on_camera_error)

        self.paintable = FramePaintable()

        self._current_wifi = None

        self._build_ui()

    def _build_ui(self):
        main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.set_content(main_box)

        header = Adw.HeaderBar()
        main_box.append(header)

        clamp = Adw.Clamp(maximum_size=480)
        main_box.append(clamp)

        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=18,
                          margin_start=18, margin_end=18,
                          margin_top=18, margin_bottom=18)
        clamp.set_child(content)

        # ── Camera view ──
        self.camera_frame = Gtk.Frame(halign=Gtk.Align.CENTER)
        self.camera_frame.add_css_class("view")
        self.camera_frame.set_size_request(360, 270)

        self.picture = Gtk.Picture.new_for_paintable(self.paintable)
        self.picture.set_content_fit(Gtk.ContentFit.CONTAIN)
        self.camera_frame.set_child(self.picture)

        content.append(self.camera_frame)

        # Camera status label
        self.cam_status = Gtk.Label(label="Camera: Off")
        self.cam_status.add_css_class("dim-label")
        content.append(self.cam_status)

        # ── Camera toggle button ──
        self.cam_button = Gtk.Button(label="Start Camera",
                                      halign=Gtk.Align.CENTER)
        self.cam_button.add_css_class("suggested-action")
        self.cam_button.add_css_class("pill")
        self.cam_button.connect("clicked", self._on_toggle_camera)
        content.append(self.cam_button)

        # ── Separator ──
        content.append(Gtk.Separator())

        # ── Image file button ──
        self.file_button = Gtk.Button(label="Open Image File…",
                                       halign=Gtk.Align.CENTER)
        self.file_button.add_css_class("pill")
        self.file_button.connect("clicked", self._on_open_file)
        content.append(self.file_button)

        # ── Parsed WiFi info card ──
        self.info_group = Adw.PreferencesGroup(title="Detected Network")
        self.info_group.set_visible(False)
        content.append(self.info_group)

        self.ssid_row = Adw.ActionRow(title="SSID")
        self.info_group.add(self.ssid_row)

        self.auth_row = Adw.ActionRow(title="Security")
        self.info_group.add(self.auth_row)

        self.pass_row = Adw.ActionRow(title="Password")
        self.info_group.add(self.pass_row)

        self.hidden_row = Adw.ActionRow(title="Hidden")
        self.info_group.add(self.hidden_row)

        # ── Connect button ──
        self.connect_button = Gtk.Button(
            label="Connect to Network",
            halign=Gtk.Align.CENTER,
            margin_top=6,
            sensitive=False,
        )
        self.connect_button.add_css_class("suggested-action")
        self.connect_button.add_css_class("pill")
        self.connect_button.connect("clicked", self._on_connect)
        content.append(self.connect_button)

        # ── Status label ──
        self.status_label = Gtk.Label(wrap=True, justify=Gtk.Justification.CENTER)
        self.status_label.add_css_class("dim-label")
        content.append(self.status_label)

        # ── Spinner ──
        self.spinner = Gtk.Spinner(halign=Gtk.Align.CENTER)
        self.spinner.set_visible(False)
        content.append(self.spinner)

    # ── Camera handling ──
    def _on_frame_ready(self, camera, frame):
        """Called on main thread when a new camera frame is available."""
        self.paintable.update_frame(frame)

    def _on_toggle_camera(self, btn):
        if self.camera._running:
            self.camera.stop()
            self.cam_button.set_label("Start Camera")
            self.cam_button.remove_css_class("destructive-action")
            self.cam_status.set_text("Camera: Off")
            self.paintable._texture = None
            self.paintable.invalidate_contents()
        else:
            self.cam_status.set_text("Starting camera…")
            self.camera.start()
            self.cam_button.set_label("Stop Camera")
            self.cam_button.add_css_class("destructive-action")
            self.cam_button.remove_css_class("suggested-action")
            self.cam_status.set_text("Camera: On — point at QR code")

    def _on_camera_error(self, camera_manager, message):
        self.cam_status.set_text(f"Camera error: {message}")
        self.cam_button.set_label("Start Camera")
        self.cam_button.remove_css_class("destructive-action")
        self.cam_button.add_css_class("suggested-action")

    # ── File handling ──
    def _on_open_file(self, btn):
        dialog = Gtk.FileDialog()
        dialog.set_title("Select QR Code Image")
        ff = Gtk.FileFilter()
        ff.set_name("Images")
        ff.add_mime_type("image/png")
        ff.add_mime_type("image/jpeg")
        ff.add_mime_type("image/webp")
        ff.add_mime_type("image/bmp")
        filters = Gio.ListStore.new(Gtk.FileFilter)
        filters.append(ff)
        dialog.set_filters(filters)

        dialog.open(self, None, self._on_file_chosen)

    def _on_file_chosen(self, dialog, result):
        try:
            file = dialog.open_finish(result)
        except GLib.Error:
            return  # User cancelled

        path = file.get_path()
        self.status_label.set_text(f"Scanning {path}…")

        def do_decode():
            try:
                img = Image.open(path)
                codes = pyzbar_decode(img)
                if codes:
                    raw = codes[0].data.decode("utf-8", errors="replace")
                    GLib.idle_add(self._on_qr_detected, None, raw)
                    return
                # Fallback to zbarimg CLI
                result = subprocess.run(
                    ["zbarimg", "--raw", "--quiet", path],
                    capture_output=True, text=True, timeout=10
                )
                if result.returncode == 0 and result.stdout.strip():
                    raw = result.stdout.strip()
                    GLib.idle_add(self._on_qr_detected, None, raw)
                else:
                    GLib.idle_add(self._set_status, "No QR code found in image")
            except Exception as e:
                GLib.idle_add(self._set_status, f"Error: {e}")

        threading.Thread(target=do_decode, daemon=True).start()

    # ── QR detection ──
    def _on_qr_detected(self, source, raw_text):
        """Called when a QR code is detected (from camera or file)."""
        info = parse_wifi_qr(raw_text)
        if not info:
            self._set_status(f"Not a WiFi QR code: {raw_text[:60]}…")
            return

        self._current_wifi = info

        self.ssid_row.set_subtitle(info["ssid"])
        self.auth_row.set_subtitle(info["auth"])
        if info["password"]:
            self.pass_row.set_subtitle("•" * min(len(info["password"]), 20))
        else:
            self.pass_row.set_subtitle("(none)")
        self.hidden_row.set_subtitle(info["hidden"])

        self.info_group.set_visible(True)
        self.connect_button.set_sensitive(True)
        self._set_status("WiFi QR code detected. Click Connect.")

    # ── Connection ──
    def _on_connect(self, btn):
        if not self._current_wifi:
            return

        self.connect_button.set_sensitive(False)
        self.spinner.set_visible(True)
        self.spinner.start()
        self._set_status("Connecting…")

        info = self._current_wifi

        def do_connect():
            success, msg = connect_wifi(info)
            GLib.idle_add(self._on_connect_done, success, msg)

        threading.Thread(target=do_connect, daemon=True).start()

    def _on_connect_done(self, success, msg):
        self.spinner.stop()
        self.spinner.set_visible(False)
        self.connect_button.set_sensitive(True)

        if success:
            self._set_status(f"✓ {msg}")
        else:
            self._set_status(f"✗ {msg}")

    def _set_status(self, text):
        self.status_label.set_text(text)

    def cleanup(self):
        self.camera.stop()


# ── Application ──────────────────────────────────────────────────────────
class WifiQRApp(Adw.Application):
    def __init__(self):
        super().__init__(application_id="com.luandro.wifiqr")

    def do_activate(self):
        win = WifiQRWindow(application=self)
        win.present()

    def do_shutdown(self):
        win = self.get_active_window()
        if win:
            win.cleanup()
        Gst.deinit()


def main():
    app = WifiQRApp()
    return app.run(sys.argv)


if __name__ == "__main__":
    sys.exit(main())
